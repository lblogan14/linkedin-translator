# ============================================================================
#  LLM provider — the app is provider-agnostic. Pick ONE.
#  Supported: google | openai | anthropic
# ============================================================================
LLM_PROVIDER=google

# Optional: override the model id. If unset, a sensible default is used per
# provider:
#   google    -> gemini-2.5-flash
#   openai    -> gpt-4o-mini
#   anthropic -> claude-haiku-4-5-20251001
# LLM_MODEL=

# Optional: max output tokens (default 2048)
# LLM_MAX_TOKENS=2048

# ----------------------------------------------------------------------------
#  API keys — set only the one for the provider you selected above.
# ----------------------------------------------------------------------------
# google    (get one free at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# openai    (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
#  Server
# ----------------------------------------------------------------------------
PORT=8787

# Web-search grounding for the post generator. Only takes effect when the
# selected provider has a built-in search tool (currently: google).
ENABLE_WEB_SEARCH=true

# ----------------------------------------------------------------------------
#  Optional: LangSmith tracing for debugging the graphs
# ----------------------------------------------------------------------------
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=linkedin-translator
